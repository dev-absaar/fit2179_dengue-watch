{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Monthly Dengue Patterns by State (2010)",
    "subtitle": "Each state peaks at a different month — one control strategy does not fit all",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "subtitleColor": "#6B6B6B",
    "anchor": "start"
  },
  "data": {"url": "data/dengue_small_multiples.csv"},
  "facet": {
    "field": "state",
    "type": "nominal",
    "columns": 2,
    "header": {
      "title": null,
      "labelFontSize": 13,
      "labelFontWeight": "bold",
      "labelColor": "#424242",
      "labelPadding": 6
    }
  },
  "spec": {
    "width": 300,
    "height": 120,
    "mark": {
      "type": "area",
      "color": "#F4A261",
      "line": {"color": "#B84203", "strokeWidth": 2},
      "opacity": 0.55
    },
    "encoding": {
      "x": {
        "field": "month_num",
        "type": "ordinal",
        "title": "Month",
        "axis": {
          "labelExpr": "['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][datum.value - 1]",
          "labelFontSize": 9,
          "labelAngle": -45,
          "grid": false
        }
      },
      "y": {
        "field": "cases",
        "type": "quantitative",
        "title": "Cases",
        "axis": {
          "labelFontSize": 9,
          "tickCount": 4,
          "titleFontSize": 9
        }
      },
      "tooltip": [
        {"field": "state", "type": "nominal", "title": "State"},
        {"field": "month", "type": "nominal", "title": "Month"},
        {"field": "cases", "type": "quantitative", "title": "Cases", "format": ","}
      ]
    }
  },
  "config": {
    "facet": {"spacing": 20}
  }
}
