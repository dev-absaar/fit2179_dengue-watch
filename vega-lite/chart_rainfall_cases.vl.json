{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "data": {"url": "data/rainfall_dengue_annual.csv"},
  "layer": [
    {
      "mark": {"type": "bar", "color": "#ADE8F4", "opacity": 0.8},
      "encoding": {
        "x": {"field": "year", "type": "ordinal", "title": "Year"},
        "y": {
          "field": "rainfall_mm",
          "type": "quantitative",
          "title": "Annual Rainfall (mm)",
          "axis": {"titleColor": "#0077B6"}
        },
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "rainfall_mm", "type": "quantitative", "title": "Rainfall (mm)", "format": ","},
          {"field": "national_cases", "type": "quantitative", "title": "Dengue Cases", "format": ","}
        ]
      }
    },
    {
      "mark": {"type": "line", "color": "#B84203", "strokeWidth": 3, "point": {"color": "#B84203", "size": 80}},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {
          "field": "national_cases",
          "type": "quantitative",
          "title": "National Dengue Cases",
          "axis": {"titleColor": "#B84203", "orient": "right"}
        }
      }
    }
  ],
  "resolve": {"scale": {"y": "independent"}}
}
