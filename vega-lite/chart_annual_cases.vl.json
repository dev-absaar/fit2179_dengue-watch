{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 320,
  "data": {"url": "data/dengue_annual_national.csv"},
  "layer": [
    {
      "mark": {"type": "area", "color": "#FEE8C8", "line": {"color": "#B84203", "strokeWidth": 2.5}, "opacity": 0.5},
      "encoding": {
        "x": {"field": "year", "type": "ordinal", "title": "Year", "axis": {"labelAngle": -45}},
        "y": {"field": "cases", "type": "quantitative", "title": "Dengue Cases", "axis": {"format": ",.0f"}}
      }
    },
    {
      "mark": {"type": "circle", "size": 70, "color": "#B84203"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "cases", "type": "quantitative"},
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "cases", "type": "quantitative", "title": "Cases", "format": ","}
        ]
      }
    },
    {
      "mark": {"type": "text", "dy": -14, "fontSize": 10, "fontWeight": 600, "color": "#7F2704"},
      "transform": [{"filter": "datum.cases > 100000"}],
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "cases", "type": "quantitative"},
        "text": {"field": "cases", "type": "quantitative", "format": ",.0f"}
      }
    }
  ]
}
